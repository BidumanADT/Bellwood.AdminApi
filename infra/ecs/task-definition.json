{
  "family": "bellwood-adminapi",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [ "FARGATE" ],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::105319843299:role/bellwood-ecs-task-execution-role",
  "taskRoleArn": "arn:aws:iam::105319843299:role/bellwood-adminapi-task-role",
  "volumes": [
    {
      "name": "app-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-039a9f1651c4cf2fe",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "accessPointId": "fsap-08ad20dd4dd547495",
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "bellwood-adminapi",
      "image": "105319843299.dkr.ecr.us-east-1.amazonaws.com/bellwood-adminapi:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "app-data",
          "containerPath": "/app/App_Data",
          "readOnly": false
        }
      ],
      "environment": [
        {
          "name": "ASPNETCORE_ENVIRONMENT",
          "value": "Alpha"
        },
        {
          "name": "ASPNETCORE_URLS",
          "value": "http://+:8080"
        },
        {
          "name": "ASPNETCORE_FORWARDEDHEADERS_ENABLED",
          "value": "true"
        },
        {
          "name": "AuthServer__Url",
          "value": "https://auth.elitebellwood.com"
        },
        {
          "name": "Jwt__Authority",
          "value": "https://auth.elitebellwood.com"
        }
      ],
      "secrets": [
        {
          "name": "Jwt__Key",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/adminapi/jwt-key"
        },
        {
          "name": "Email__Smtp__Password",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/adminapi/smtp-password"
        },
        {
          "name": "Email__Smtp__Host",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/adminapi/smtp-host"
        },
        {
          "name": "Email__Smtp__From",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/adminapi/smtp-from"
        },
        {
          "name": "Email__Smtp__Username",
          "valueFrom": "arn:aws:ssm:us-east-1:105319843299:parameter/bellwood/alpha/adminapi/smtp-username"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/bellwood-adminapi",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
